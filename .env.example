# Copy to .env and fill in. `docker compose -f docker-compose.prod.yml` reads it
# automatically. Do NOT commit the real .env (add it to .gitignore).

# --- Edge ---------------------------------------------------------------
# Public hostname for Caddy auto-HTTPS. Use ":80" for local/no-TLS testing.
DOMAIN=maps.example.com
# Browser origins allowed for CORS/WebSocket (your frontend URL).
ALLOWED_ORIGINS=https://maps.example.com

# --- Shared Postgres + PostGIS (one instance, two databases) -----------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-strong-password
CATALOG_DB=mapgenie               # catalog (PostGIS) — tile reads it read-only
ACCOUNTS_DB=ritchermap_accounts   # accounts (Rails) auto-creates/migrates this

# --- Secrets ------------------------------------------------------------
# HS256 secret: accounts signs session JWTs, gateway validates them. MUST match.
# Generate: openssl rand -hex 32
JWT_SECRET=replace-with-openssl-rand-hex-32
# Rails credentials key — contents of src/accounts/config/master.key. Required.
RAILS_MASTER_KEY=

# --- Catalog JVM (cheap box: cap the heap) ------------------------------
# Override the image default if you want a different cap.
# CATALOG_JAVA_OPTS=-Xmx320m -XX:MaxMetaspaceSize=128m -XX:+UseSerialGC

# --- Tile read path -----------------------------------------------------
# Where the read path fetches tiles. Points at the same object store the tiler
# writes to. The bucket must be readable over HTTP (set a public-read policy on
# MinIO, or use a Cloudflare R2 public bucket / CDN base URL here).
TILE_ORIGIN=http://minio:9000/tiles
TILE_CACHE_MB=128

# --- Object storage for tiles (MinIO on-box by default) -----------------
# To use Cloudflare R2 instead: set S3_ENDPOINT to your R2 endpoint and the
# access keys, and drop the minio service from the compose file.
TILES_BUCKET=tiles
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=change-me-too
S3_REGION=us-east-1
CDN_BASE_URL=                      # public base URL recorded in tile manifests
