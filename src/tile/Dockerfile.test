# Hermetic test image for tile-service (Rust). No database needed: the read
# path is unit-tested against the in-memory MarkerRepo.
#   docker build -f Dockerfile.test -t tile-test .
#   docker run --rm tile-test
FROM rust:1.94-slim-bookworm

WORKDIR /app
COPY . .
# build.rs compiles the catalog proto during the test build, so the shared
# contract must be present. Supplied as a named build context (the proto tree
# lives outside this service dir); codegen is pure Rust, no protoc needed.
COPY --from=proto . /proto
ENV RITCHERMAP_PROTO_DIR=/proto

CMD ["cargo", "test", "--all-targets", "--locked"]
